NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_STORE_DOMAIN="sitiohoy.com"

# URL del sitio público (para invalidar caché al guardar productos/categorías)
# Solo necesario para planes emprendimiento/empresa
# En desarrollo apunta al puerto donde corre el sitio (ej. http://localhost:3001)
# En producción apunta al dominio del cliente (ej. https://tutienda.com)
STORE_URL=http://localhost:3001
STORE_REVALIDATION_SECRET=cambiar-antes-del-deploy-minimo-24-caracteres-xxx

# Umami Analytics (opcional)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
